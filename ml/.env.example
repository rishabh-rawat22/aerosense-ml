# FILE: ml/.env.example
# Copy this to ml/.env and fill in values.
# The ML service reads from server/.env first, then ml/.env.

# ── Required (shared with Node.js server) ─────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/aerosense

# ── ML-specific ───────────────────────────────────────────────────────────────
# Directory where .pt checkpoints are stored
MODEL_CHECKPOINT_DIR=./models/checkpoints

# Hours after which a model checkpoint is considered stale
ML_STALE_HOURS=24

# Fine-tuning window in days (how far back nightly job looks)
FINETUNE_DAYS=90

# ── Optional ──────────────────────────────────────────────────────────────────
# OpenAQ API key — free tier works without it, but key raises rate limits
# Get from: https://explore.openaq.org/register
OPENAQ_API_KEY=

# Path to downloaded Kaggle city_day.csv for initial backfill
# Download: https://www.kaggle.com/datasets/rohanrao/air-quality-data-in-india
KAGGLE_CSV_PATH=/path/to/city_day.csv
